<%- include('partials/top', { title: 'Yeni Konu - ' + category.name }) %>

<nav class="hm-breadcrumb">
  <a href="/">Anasayfa</a><span class="hm-bc-sep">/</span>
  <a href="/<%= category.slug %>"><%= category.name %></a><span class="hm-bc-sep">/</span>
  <span class="hm-bc-current">Yeni Konu</span>
</nav>

<div class="forum-block mf-editor-block">
  <div class="forum-header"><i class="fas fa-pen"></i> Yeni Konu Aç - <%= category.name %></div>
  <% if (error) { %><div class="mf-alert mf-alert-error"><%= error %></div><% } %>
  <form method="post" action="/<%= category.slug %>/yeni-konu">
    <input type="text" name="title" placeholder="Konu başlığı" value="<%= old.title || '' %>" required maxlength="180">
    <%- include('partials/editor-toolbar', { textareaId: 'threadBody' }) %>
    <textarea id="threadBody" name="body" rows="10" placeholder="Konu içeriği..." required><%= old.body || '' %></textarea>
    <button type="submit" class="mf-cta"><i class="fas fa-paper-plane"></i> Konuyu Yayınla</button>
  </form>
</div>

<%- include('partials/footer') %>
