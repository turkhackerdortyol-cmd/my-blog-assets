# Supabase Ayarları (Supabase Dashboard > Project Settings > API)
SUPABASE_URL=https://xxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# Oturum / şifreleme
JWT_SECRET=cok-gizli-bir-anahtar-buraya

# Site
SITE_URL=http://localhost:3000
PORT=3000

# E-posta (şifremi unuttum linki göndermek için - SMTP)
# Boş bırakılırsa reset linki konsola yazdırılır (geliştirme modu)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="MiFRM Forum <no-reply@mifrm.eu.cc>"

# İlk admin (npm run seed ile oluşturulur)
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_EMAIL=admin@mifrm.eu.cc
SEED_ADMIN_PASSWORD=DegistirilecekSifre123
